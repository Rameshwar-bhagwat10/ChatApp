{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"strict": true,
		"allowJs": false,
		"lib": ["dom", "dom.iterable", "esnext"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"jsx": "preserve",
		"isolatedModules": true,
		"incremental": true,
		"noEmit": true,
		"plugins": [{ "name": "next" }]
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
