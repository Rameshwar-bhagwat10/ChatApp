{
	"name": "@chat-app/api",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/server.js",
		"lint": "eslint src --ext .ts",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "tsx --test src/**/*.test.ts",
		"test:postgres-real": "tsx --test src/modules/auth/auth.postgres-real.integration.ts"
	},
	"dependencies": {
		"@chat-app/config": "file:../../packages/config",
		"@chat-app/types": "file:../../packages/types",
		"@chat-app/utils": "file:../../packages/utils",
		"bcrypt": "^6.0.0",
		"cors": "^2.8.5",
		"express": "^4.21.2",
		"jsonwebtoken": "^9.0.3",
		"pg": "^8.16.0",
		"pg-mem": "^3.0.5",
		"zod": "^4.4.1"
	},
	"devDependencies": {
		"@types/bcrypt": "^6.0.0",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/pg": "^8.15.2",
		"@types/supertest": "^7.2.0",
		"supertest": "^7.2.2"
	}
}
