generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @db.Uuid
  email        String         @unique
  username     String         @unique
  passwordHash String         @map("password_hash")
  createdAt    DateTime       @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt    DateTime       @default(now()) @db.Timestamptz(6) @map("updated_at")
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id                String    @id @db.Uuid
  userId            String    @db.Uuid @map("user_id")
  tokenFamilyId     String    @db.Uuid @map("token_family_id")
  tokenHash         String    @unique @map("token_hash")
  expiresAt         DateTime  @db.Timestamptz(6) @map("expires_at")
  createdAt         DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  lastUsedAt        DateTime? @db.Timestamptz(6) @map("last_used_at")
  revokedAt         DateTime? @db.Timestamptz(6) @map("revoked_at")
  replacedByTokenId String?   @db.Uuid @map("replaced_by_token_id")
  userAgent         String?   @map("user_agent")
  ipAddress         String?   @map("ip_address")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@index([expiresAt], map: "idx_refresh_tokens_expires_at")
  @@index([tokenFamilyId], map: "idx_refresh_tokens_token_family_id")
  @@map("refresh_tokens")
}

model AuthRateLimit {
  routeKey    String   @map("route_key")
  identifier  String
  windowStart DateTime @db.Timestamptz(6) @map("window_start")
  attemptCount Int     @default(1) @map("attempt_count")
  updatedAt   DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  @@id([routeKey, identifier, windowStart])
  @@map("auth_rate_limits")
}

model AuthAdminAuditLog {
  id                 String   @id @db.Uuid
  action             String
  actorType          String   @map("actor_type")
  actorIdentifier    String   @map("actor_identifier")
  actorIpAddress     String?  @map("actor_ip_address")
  actorUserAgent     String?  @map("actor_user_agent")
  targetUserId       String   @db.Uuid @map("target_user_id")
  status             String
  revokedSessionCount Int     @default(0) @map("revoked_session_count")
  errorMessage       String?  @map("error_message")
  createdAt          DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  @@index([targetUserId], map: "idx_auth_admin_audit_logs_target_user_id")
  @@index([createdAt], map: "idx_auth_admin_audit_logs_created_at")
  @@map("auth_admin_audit_logs")
}
