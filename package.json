{
	"name": "chat-app",
	"version": "0.1.0",
	"private": true,
	"packageManager": "npm@10.8.2",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo run dev --filter=@chat-app/web --filter=@chat-app/api --filter=@chat-app/socket --filter=@chat-app/worker",
		"build": "turbo run build",
		"lint": "turbo run lint",
		"typecheck": "turbo run typecheck",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"devDependencies": {
		"@types/node": "^22.15.2",
		"@typescript-eslint/eslint-plugin": "^8.31.0",
		"@typescript-eslint/parser": "^8.31.0",
		"eslint": "^8.57.1",
		"eslint-config-next": "^14.2.35",
		"eslint-config-prettier": "^10.1.2",
		"prettier": "^3.5.3",
		"tsx": "^4.19.4",
		"turbo": "^2.5.1",
		"typescript": "^5.8.3"
	}
}
